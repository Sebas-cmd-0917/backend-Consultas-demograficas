# Server
PORT=3000
NODE_ENV=production

# Database — Railway provides this automatically when you add a MySQL plugin
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@host:3306/demographics_db"

# Optional — protects the POST ingestion endpoint. When set, the n8n HTTP node
# must send the header  x-api-key: <this value>. Leave empty to keep it open.
INGEST_API_KEY=

# Optional — restrict CORS to specific origins (comma-separated). Empty = allow any.
# e.g. CORS_ORIGIN=https://frontend-consultas-demograficas.vercel.app
CORS_ORIGIN=
